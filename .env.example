# Copy to .env and adjust as needed.
# Used by Go services when running on the host (dev) or in containers (prod).

# Kafka bootstrap. From host: localhost:9092. From a container on the
# compose network: kafka:29092.
KAFKA_BOOTSTRAP=localhost:9092

# Postgres DSN. From host: localhost. From a container: postgres.
DATABASE_URL=postgres://jobtracker:jobtracker@localhost:5432/jobtracker?sslmode=disable
