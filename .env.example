# Copy to .env and adjust as needed.
# Used by Go services when running on the host (dev) or in containers (prod).

# Kafka bootstrap. From host: localhost:9092. From a container on the
# compose network: kafka:29092.
KAFKA_BOOTSTRAP=localhost:9092

# Postgres DSN. From host: localhost. From a container: postgres.
DATABASE_URL=postgres://jobtracker:jobtracker@localhost:5432/jobtracker?sslmode=disable

# Telegram notifications (optional). Get the token from @BotFather; get the
# chat ID by messaging the bot and hitting
# https://api.telegram.org/bot<TOKEN>/getUpdates. If either is unset, the
# notifier still logs reminders to stdout but skips Telegram delivery.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Reminder snapping: round computed due_at forward to REMINDER_HOUR in
# REMINDER_TZ so reminders land in the morning instead of whenever the
# job happened to be saved. Set REMINDER_HOUR=-1 to disable (useful when
# REMINDER_SAVED_SECONDS is small for testing).
REMINDER_HOUR=9
REMINDER_TZ=Asia/Kolkata
